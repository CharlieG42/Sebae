# =============================================================================
# Sebae Configuration - Example Environment File
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# =============================================================================

# Database Configuration
# Supported types: "sqlite" or "access"
DB_TYPE=sqlite
DB_PATH=sebae.db

# Admin Credentials
# Generate password hash with: python -c "import hashlib; print(hashlib.sha256(input('Password: ').encode()).hexdigest())"
ADMIN_LOGIN=admin
ADMIN_PASSWORD_SHA=

# Logging Configuration (optional)
LOG_LEVEL=INFO
LOG_FILE=sebae.log
